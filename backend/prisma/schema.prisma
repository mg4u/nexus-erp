// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════

enum UserRole {
  ADMIN
  MANAGER
  ACCOUNTANT
  EMPLOYEE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum PaymentMethod {
  BANK_TRANSFER
  CREDIT_CARD
  CASH
  PAYPAL
  STRIPE
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalStatus {
  DRAFT
  POSTED
  REVERSED
}

// ═══════════════════════════════════════════════
// TENANT (Company / Organization)
// ═══════════════════════════════════════════════

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      String   @default("starter") // starter, pro, enterprise
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users          User[]
  products       Product[]
  customers      Customer[]
  orders         Order[]
  invoices       Invoice[]
  payments       Payment[]
  auditLogs      AuditLog[]
  accounts       Account[]
  journalEntries JournalEntry[]

  @@map("tenants")
}

// ═══════════════════════════════════════════════
// USER
// ═══════════════════════════════════════════════

model User {
  id           String    @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole  @default(EMPLOYEE)
  isActive     Boolean   @default(true)
  refreshToken String?   // hashed refresh token
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditLogs    AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

// ═══════════════════════════════════════════════
// PRODUCT
// ═══════════════════════════════════════════════

model Product {
  id            String   @id @default(uuid())
  tenantId      String
  name          String
  description   String?
  sku           String
  price         Decimal  @db.Decimal(10, 2)
  stockQuantity Int      @default(0)
  lowStockAlert Int      @default(10)
  category      String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, category])
  @@index([tenantId, isActive])
  @@map("products")
}

// ═══════════════════════════════════════════════
// CUSTOMER
// ═══════════════════════════════════════════════

model Customer {
  id        String   @id @default(uuid())
  tenantId  String
  firstName String
  lastName  String
  email     String
  phone     String?
  address   String?
  city      String?
  country   String?
  taxNumber String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, email])
  @@map("customers")
}

// ═══════════════════════════════════════════════
// ORDER
// ═══════════════════════════════════════════════

model Order {
  id         String      @id @default(uuid())
  tenantId   String
  customerId String
  orderNumber String     @default(uuid())
  status     OrderStatus @default(PENDING)
  subtotal   Decimal     @db.Decimal(10, 2) @default(0)
  taxAmount  Decimal     @db.Decimal(10, 2) @default(0)
  total      Decimal     @db.Decimal(10, 2) @default(0)
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  // Relations
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer   Customer    @relation(fields: [customerId], references: [id])
  items      OrderItem[]
  invoice    Invoice?

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@index([tenantId, createdAt])
  @@map("orders")
}

// ═══════════════════════════════════════════════
// ORDER ITEM
// ═══════════════════════════════════════════════

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  productId  String
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  totalPrice Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())

  // Relations
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ═══════════════════════════════════════════════
// INVOICE
// ═══════════════════════════════════════════════

model Invoice {
  id             String        @id @default(uuid())
  tenantId       String
  orderId        String        @unique
  invoiceNumber  String
  status         InvoiceStatus @default(DRAFT)
  journalEntryId String?
  dueDate        DateTime
  subtotal       Decimal       @db.Decimal(10, 2)
  taxAmount      Decimal       @db.Decimal(10, 2) @default(0)
  total          Decimal       @db.Decimal(10, 2)
  notes          String?
  sentAt         DateTime?
  paidAt         DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order         Order         @relation(fields: [orderId], references: [id])
  journalEntry  JournalEntry? @relation("InvoiceJournal", fields: [journalEntryId], references: [id])
  payments      Payment[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@index([journalEntryId])
  @@map("invoices")
}

// ═══════════════════════════════════════════════
// PAYMENT
// ═══════════════════════════════════════════════

model Payment {
  id             String        @id @default(uuid())
  tenantId       String
  invoiceId      String
  journalEntryId String?
  amount         Decimal       @db.Decimal(10, 2)
  method         PaymentMethod
  reference      String?       // External payment reference
  notes          String?
  paidAt         DateTime      @default(now())
  createdAt      DateTime      @default(now())

  // Relations
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice       Invoice       @relation(fields: [invoiceId], references: [id])
  journalEntry  JournalEntry? @relation("PaymentJournal", fields: [journalEntryId], references: [id])

  @@index([tenantId])
  @@index([tenantId, invoiceId])
  @@index([tenantId, paidAt])
  @@index([journalEntryId])
  @@map("payments")
}

// ═══════════════════════════════════════════════
// AUDIT LOG
// ═══════════════════════════════════════════════

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String?
  action    String   // CREATE, UPDATE, DELETE
  entity    String   // User, Product, Order, etc.
  entityId  String
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  // Relations
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User?  @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([tenantId, entity])
  @@index([tenantId, userId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

// ═══════════════════════════════════════════════
// CHART OF ACCOUNTS
// ═══════════════════════════════════════════════

model Account {
  id        String      @id @default(uuid())
  tenantId  String
  code      String
  name      String
  type      AccountType
  parentId  String?
  level     Int         @default(0)
  isSystem  Boolean     @default(false)
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  isPostable Boolean     @default(false)

  // Relations
  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent           Account?           @relation("AccountHierarchy", fields: [parentId], references: [id])
  children         Account[]          @relation("AccountHierarchy")
  journalEntryLines JournalEntryLine[]

  @@unique([tenantId, code])
  @@index([tenantId, parentId])
  @@index([tenantId, type])
  @@index([tenantId, isActive])
  @@index([tenantId, isPostable])
  @@index([tenantId, createdAt])
  @@map("accounts")
}

// ═══════════════════════════════════════════════
// JOURNAL ENTRY
// ═══════════════════════════════════════════════

model JournalEntry {
  id            String        @id @default(uuid())
  tenantId      String
  referenceType String?       // "INVOICE" | "PAYMENT" | "MANUAL"
  referenceId   String?       // FK to invoice/payment id (not enforced by Prisma relation — flexible ref)
  description   String
  status        JournalStatus @default(DRAFT)
  postedAt      DateTime?
  reversalOf    String?       // Self-referential FK to the original journal entry
  createdBy     String        // FK to users.id
  createdAt     DateTime      @default(now())

  // Relations
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  originalEntry JournalEntry?      @relation("JournalReversal", fields: [reversalOf], references: [id])
  reversals     JournalEntry[]     @relation("JournalReversal")
  lines         JournalEntryLine[]
  invoices      Invoice[]          @relation("InvoiceJournal")
  payments      Payment[]          @relation("PaymentJournal")

  @@index([tenantId, status, postedAt])
  @@index([tenantId, referenceType, referenceId])
  @@index([tenantId, createdAt])
  @@map("journal_entries")
}

// ═══════════════════════════════════════════════
// JOURNAL ENTRY LINE
// ═══════════════════════════════════════════════

model JournalEntryLine {
  id             String       @id @default(uuid())
  journalEntryId String
  accountId      String
  debit          Decimal      @db.Decimal(18, 4) @default(0)
  credit         Decimal      @db.Decimal(18, 4) @default(0)
  description    String?

  // Relations
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account        Account      @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_entry_lines")
}
