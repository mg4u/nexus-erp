# ═══════════════════════════════════════════════════════════════════
# SaaS ERP Platform — Environment Variables
# Copy this file to .env and fill in all values marked as REQUIRED
# ═══════════════════════════════════════════════════════════════════

# ─── App ────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (PostgreSQL) ──────────────────────────────────────
# REQUIRED: Connection string for Prisma
DATABASE_URL=postgresql://erp_user:erp_secret_password@localhost:5432/saas_erp

# Docker postgres service config
POSTGRES_DB=saas_erp
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=erp_secret_password
POSTGRES_PORT=5432

# ─── JWT (REQUIRED — generate with: openssl rand -base64 64) ────
JWT_ACCESS_SECRET=CHANGE_ME_generate_a_64_char_random_string_here_abcdefghijklmnopqrstuvwxyz
JWT_REFRESH_SECRET=CHANGE_ME_generate_another_64_char_random_string_here_0123456789ab
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Redis ──────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# ─── OpenAI (optional — leave empty to use Stub provider) ───────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ─── Security ───────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# ─── Frontend ───────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000/api

# ─── Docker Ports ───────────────────────────────────────────────
BACKEND_PORT=3000
FRONTEND_PORT=80
